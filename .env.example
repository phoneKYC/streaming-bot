# Streaming Bot Environment Variables

# Telegram Bot Token
# Get your token from @BotFather on Telegram
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Database path (default: stream_manager.db)
DATABASE_PATH=./stream_manager.db

# Optional: FFmpeg timeout in milliseconds
FFMPEG_TIMEOUT=15000000

# Optional: Reconnect delay in seconds
RECONNECT_DELAY=5

# Optional: Enable debug mode (true/false)
DEBUG=false
